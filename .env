UPLOAD_DIR=./uploads

# MinIO (only needed if MEDIA_STORAGE=minio)
# Self-hosted MinIO endpoint — no trailing slash
MINIO_ENDPOINT=play.min.io
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=whatsapp-media
# Public base URL used to build object URLs (set to MinIO console proxy or CDN)
# Example: http://localhost:9000  or  https://media.yourdomain.com
MINIO_PUBLIC_URL=https://play.min.io:9000


