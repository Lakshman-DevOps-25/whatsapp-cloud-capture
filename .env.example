# ─── Server ──────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── MongoDB ─────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/whatsapp_capture

# ─── WhatsApp Cloud API (Meta Developer Console) ─────────
# WA_PHONE_NUMBER_ID  → the numeric ID used in API calls (e.g. 123456789012345)
#                       Meta Dashboard → WhatsApp → API Setup → Phone Number ID
WA_PHONE_NUMBER_ID=your_phone_number_id

# WA_BUSINESS_PHONE   → your actual phone number in E.164 (stored in MongoDB as from/to)
#                       e.g. 919000000000  (no +, no spaces, include country code)
#                       Meta Dashboard → WhatsApp → API Setup → Phone Number display value
WA_BUSINESS_PHONE=919000000000      # ← REQUIRED: your real WA number (E.164, no +)

WA_BUSINESS_ACCOUNT_ID=your_whatsapp_business_account_id
WA_ACCESS_TOKEN=your_permanent_system_user_access_token
WA_VERIFY_TOKEN=your_custom_webhook_verify_token_string
WA_API_VERSION=v19.0

# ─── Media Storage ────────────────────────────────────────
MEDIA_STORAGE=minio
UPLOAD_DIR=./uploads

# ─── MinIO ───────────────────────────────────────────────
MINIO_INTERNAL_URL=https://play.min.io:9000
MINIO_PUBLIC_URL=https://play.min.io:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=whatsapp-media
