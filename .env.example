# ─── Server ──────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── MongoDB ─────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/whatsapp_capture
# For Atlas: mongodb+srv://<user>:<pass>@cluster.mongodb.net/whatsapp_capture

# ─── WhatsApp Cloud API (Meta Developer Console) ─────────
WA_PHONE_NUMBER_ID=your_phone_number_id
WA_BUSINESS_ACCOUNT_ID=your_whatsapp_business_account_id
WA_ACCESS_TOKEN=your_permanent_system_user_access_token
WA_VERIFY_TOKEN=your_custom_webhook_verify_token_string
WA_API_VERSION=v19.0

# ─── Media Storage ────────────────────────────────────────
# 'local'  → saves files to ./uploads/ folder
# 'minio'  → saves to MinIO object storage (fill keys below)
MEDIA_STORAGE=minio
UPLOAD_DIR=./uploads

# ─── MinIO (only needed if MEDIA_STORAGE=minio) ───────────
#
# MINIO_INTERNAL_URL — address this server uses to CONNECT to MinIO internally.
#   Docker (same compose network): http://minio:9000
#   Same machine:                  http://localhost:9000
#   Private network IP:            http://10.0.0.5:9000
#   Remote server (no SSL):        http://your-server-ip:9000
#   Remote server (SSL):           https://minio.yourdomain.com
#
# MINIO_INTERNAL_URL=http://localhost:9000

# MINIO_PUBLIC_URL — address the INTERNET uses to fetch stored media files.
#   This must be publicly reachable — the same domain/IP you use for your webhook.
#   Direct (HTTP, open port 9000 in firewall): http://your-server-public-ip:9000
#   With HTTPS reverse proxy (recommended):    https://media.yourdomain.com
#   ngrok tunnel (for local dev):              https://abc123.ngrok.io
#
#   ⚠️  Do NOT use localhost here — WhatsApp and browsers won't be able to reach it.
#
# MINIO_PUBLIC_URL=https://media.yourdomain.com

MINIO_INTERNAL_URL=https://play.min.io:9000
MINIO_PUBLIC_URL=https://play.min.io:9000

MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=whatsapp-media
